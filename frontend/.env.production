# Used automatically by `npm run build` (overrides .env for production builds).
# "/" normalizes to same-origin relative URLs; the _redirects file in public/
# proxies /api, /uploads and /socket.io to the backend over HTTPS.
#
# IF BACKEND MOVES TO RENDER: replace with your Render URL (NO /api suffix —
# the frontend code appends /api itself):
# VITE_API_URL=https://YOUR-APP-NAME.onrender.com
VITE_API_URL=/
